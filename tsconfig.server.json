{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "noEmit": true,
    "types": ["node"],
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["api/**/*.ts", "src/plugins/*/routes.ts", "src/plugins/schema.ts"]
}
