{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "noEmit": true,
    "types": ["node"],
    "isolatedModules": true
  },
  "include": ["api-server.ts"]
}
