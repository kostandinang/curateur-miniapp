{
  "name": "openclaw-miniapp",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@telegram-apps/sdk": "^1.0.0",
    "@telegram-apps/sdk-react": "^1.0.0",
    "@vkruglikov/react-telegram-web-app": "^2.1.0",
    "hono": "^4.12.5",
    "json5": "^2.2.3",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "server": "tsx api/server.ts",
    "lint": "biome check src/ api-server.ts",
    "lint:fix": "biome check --write src/ api-server.ts",
    "format": "biome format --write src/ api-server.ts"
  }
}
