# Curateur Miniapp Environment Variables
# Run `pnpm setup` to generate this file interactively

# OpenClaw workspace directory
WORKSPACE_DIR=/root/.openclaw/workspace

# OpenClaw config file path
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json

# Telegram bot token (auto-detected from OpenClaw config if available)
TELEGRAM_BOT_TOKEN=

# Default chat ID for Telegram messages
DEFAULT_CHAT_ID=

# CORS origin (default: allow all)
CORS_ORIGIN=*

# API server port
PORT=3002

# Secret key for browser access (use a strong random string)
VITE_SECRET_KEY=
