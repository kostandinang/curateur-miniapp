# Curateur Miniapp Environment Variables
# Copy this file to .env and fill in your values

# Secret key for miniapp access (should be a strong random string)
VITE_SECRET_KEY=your_strong_secret_key_here

# Default Telegram chat ID for API messages (optional fallback)
# DEFAULT_CHAT_ID=your_telegram_chat_id

# API server URL (defaults to same origin)
# VITE_API_URL=http://localhost:3002
